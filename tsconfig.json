{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true
	},
	"include": ["src", "tests"]
}
